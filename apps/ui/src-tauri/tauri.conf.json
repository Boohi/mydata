{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "mydata",
  "version": "0.0.0",
  "identifier": "dev.boohi.mydata",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "myData",
        "width": 1200,
        "height": 780,
        "minWidth": 1000,
        "minHeight": 640
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false,
    "targets": "all",
    "icon": []
  }
}
