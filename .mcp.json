{
  "mcpServers": {
    "smart-coding": {
      "type": "stdio",
      "command": "smart-coding-mcp",
      "args": ["--workspace", "/home/boohi/apps/mydata"]
    },
    "context7": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@upstash/context7-mcp@latest"]
    },
    "tavily": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "tavily-mcp@latest"],
      "env": {
        "TAVILY_API_KEY": "${TAVILY_API_KEY}"
      }
    }
  }
}
