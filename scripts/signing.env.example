# Copy this file to scripts/signing.env (which is gitignored) and fill in your
# Apple Developer values. Used by scripts/sign.sh.

# 10-character Apple Developer Team ID, visible at developer.apple.com → Membership.
TEAM_ID=ABCDE12345

# The signing identity as listed by `security find-identity -v -p codesigning`.
# Typically "Apple Development: Your Name (TEAMID)" for dev, or a "Developer ID
# Application" cert for distribution.
SIGNING_IDENTITY="Apple Development: Your Name (ABCDE12345)"
