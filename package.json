{
  "name": "mydata",
  "private": true,
  "version": "0.0.0",
  "engines": {
    "node": ">=20.0.0 <21.0.0",
    "npm": ">=10.0.0"
  },
  "workspaces": [
    "apps/ui",
    "packages/*"
  ],
  "scripts": {
    "lint": "eslint .",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "test": "node --test tests/e2e/*.test.mjs && npm run test --workspaces --if-present",
    "test:e2e": "node tests/e2e/native-smoke.mjs",
    "test:e2e:native": "node tests/e2e/native-smoke.mjs --require-swift",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test:privacy": "node tests/privacy-paranoia/run.mjs && node --test tests/privacy-paranoia/run.test.mjs"
  },
  "devDependencies": {
    "@eslint/js": "^9.15.0",
    "eslint": "^9.15.0",
    "globals": "^15.12.0",
    "prettier": "^3.3.3",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.15.0"
  }
}
